{
  "name": "pdfserver",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild static/viewer.ts --bundle --outfile=static/viewer.js --format=esm --target=es2020 --platform=browser --external:/pdfjs/* --external:/pdfjs/pdf.worker.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "happy-dom": "^20.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "esbuild": "^0.27.4",
    "pdfjs-dist": "^5.4.624"
  }
}
