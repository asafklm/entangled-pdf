#!/usr/bin/env python3
"""remote_pdf - CLI client for pdf_server

Mimics Zathura interface for VimTeX integration.
Supports forward search via synctex and automatic server lifecycle management.
"""

import argparse
import logging
import os
import subprocess
import sys
import time

import requests
from pathlib import Path
from typing import Optional, Tuple


# Configure logging
logging.basicConfig(
    level=logging.WARNING,
    format="%(message)s"
)
logger = logging.getLogger(__name__)


def parse_synctex_forward(value: str) -> Tuple[int, int, str]:
    """Parse --synctex-forward argument in Zathura format: line:col:texfile
    
    Args:
        value: String in format "line:col:texfile"
        
    Returns:
        Tuple of (line, col, tex_file)
        
    Raises:
        ValueError: If format is invalid
    """
    parts = value.split(":", 2)
    if len(parts) != 3:
        raise ValueError(f"Invalid --synctex-forward format: {value}. Expected: line:col:texfile")
    
    try:
        line = int(parts[0])
        col = int(parts[1])
    except ValueError:
        raise ValueError(f"Invalid line or column in: {value}")
    
    tex_file = parts[2]
    return line, col, tex_file


def get_server_url(port: int, use_http: bool = False) -> str:
    """Get server base URL for given port and protocol.
    
    Args:
        port: Server port number
        use_http: Whether to use HTTP instead of HTTPS
        
    Returns:
        Base URL string (e.g., "https://localhost:8431")
    """
    protocol = "http" if use_http else "https"
    return f"{protocol}://localhost:{port}"


def get_server_pdf(port: int, use_http: bool = False, verify_ssl: bool = False) -> Optional[str]:
    """Check if pdf_server is running and get current PDF path.
    
    Args:
        port: Server port number
        use_http: Whether to use HTTP instead of HTTPS
        verify_ssl: Whether to verify SSL certificates (disabled by default for self-signed)
        
    Returns:
        PDF file path if server is running, None otherwise
    """
    try:
        url = f"{get_server_url(port, use_http)}/state"
        response = requests.get(url, timeout=2, verify=verify_ssl)
        response.raise_for_status()
        return response.json().get("pdf_file")
    except Exception:
        return None


def start_server(pdf_file: Path, port: int, use_http: bool = False) -> bool:
    """Start pdf_server subprocess.
    
    Args:
        pdf_file: Path to PDF file to serve
        port: Port number for the server
        use_http: Whether to start server with HTTP instead of HTTPS
        
    Returns:
        True if server started successfully, False otherwise
    """
    # Find the server directory (parent of bin/ where this script lives)
    script_dir = Path(__file__).parent.resolve()
    server_dir = script_dir.parent
    
    python_exe = server_dir / "bin" / "python"
    main_py = server_dir / "main.py"
    
    if not main_py.exists():
        logger.error(f"Server not found: {main_py}")
        return False
    
    # Use system Python if venv python doesn't exist
    python_cmd = str(python_exe) if python_exe.exists() else sys.executable
    
    cmd = [
        python_cmd,
        str(main_py),
        str(pdf_file),
        f"port={port}"
    ]
    
    # Add --http flag if requested
    if use_http:
        cmd.append("--http")
    
    try:
        # Start server detached (no output capture)
        subprocess.Popen(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
            cwd=str(server_dir)
        )
        logger.info(f"Started pdf_server on port {port}")
        return True
    except Exception as e:
        logger.error(f"Failed to start server: {e}")
        return False


def send_synctex_request(
    line: int,
    col: int,
    tex_file: str,
    pdf_file: str,
    port: int,
    api_key: str,
    use_http: bool = False,
    verify_ssl: bool = False
) -> bool:
    """Send synctex forward search request to server.
    
    Args:
        line: Line number in TeX file
        col: Column number in TeX file
        tex_file: Path to TeX source file
        pdf_file: Path to PDF file
        port: Server port number
        api_key: API key for authentication
        use_http: Whether to use HTTP instead of HTTPS
        verify_ssl: Whether to verify SSL certificates (disabled by default for self-signed)
        
    Returns:
        True if request succeeded, False otherwise
    """
    url = f"{get_server_url(port, use_http)}/webhook/update"
    
    data = {
        "line": line,
        "col": col,
        "tex_file": tex_file,
        "pdf_file": pdf_file
    }
    
    headers = {
        "Content-Type": "application/json",
        "X-API-Key": api_key
    }
    
    try:
        response = requests.post(url, json=data, headers=headers, timeout=5, verify=verify_ssl)
        response.raise_for_status()
        result = response.json()
        
        if result.get("status") == "success":
            page = result.get("page")
            if page:
                logger.info(f"Forward search: page {page}")
            else:
                logger.info("PDF updated, reloading...")
            return True
        else:
            logger.warning(f"Forward search failed: {result}")
            return False
            
    except requests.exceptions.HTTPError as e:
        if e.response.status_code == 403:
            logger.error("Authentication failed: Invalid API key")
        else:
            logger.error(f"Server error: {e.response.status_code}")
        return False
    except Exception as e:
        logger.error(f"Request failed: {e}")
        return False


def shutdown_server(port: int, api_key: str, use_http: bool = False, verify_ssl: bool = False) -> bool:
    """Shutdown pdf_server gracefully.
    
    Args:
        port: Server port number
        api_key: API key for authentication
        use_http: Whether to use HTTP instead of HTTPS
        verify_ssl: Whether to verify SSL certificates (disabled by default for self-signed)
        
    Returns:
        True if shutdown succeeded, False otherwise
    """
    url = f"{get_server_url(port, use_http)}/webhook/shutdown"
    
    headers = {
        "X-API-Key": api_key
    }
    
    try:
        response = requests.post(url, headers=headers, timeout=2, verify=verify_ssl)
        return response.status_code == 200
    except Exception:
        return False


def main():
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="remote_pdf - CLI client for pdf_server",
        epilog="Mimics Zathura interface for VimTeX integration"
    )
    
    # Zathura-compatible arguments
    parser.add_argument(
        "pdf_file",
        help="Path to PDF file to view"
    )
    
    parser.add_argument(
        "-x", "--inverse-search",
        dest="inverse_search",
        help="Inverse search command (accepted for Zathura compatibility, ignored)"
    )
    
    parser.add_argument(
        "--synctex-forward",
        dest="synctex_forward",
        help="Forward search coordinates in format: line:col:texfile"
    )
    
    # Additional options
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.getenv("PDF_SERVER_PORT", "8431")),
        help="Server port (default: 8431 or PDF_SERVER_PORT env var)"
    )
    
    parser.add_argument(
        "--api-key",
        dest="api_key",
        default=os.getenv("PDF_SERVER_SECRET", "super-secret-123"),
        help="API key for authentication (default: super-secret-123 or PDF_SERVER_SECRET env var)"
    )
    
    parser.add_argument(
        "--http",
        action="store_true",
        help="Use HTTP instead of HTTPS (server must be started with --http)"
    )
    
    parser.add_argument(
        "--verify-ssl",
        action="store_true",
        dest="verify_ssl",
        help="Verify SSL certificates (default: skip verification for self-signed certs)"
    )
    
    parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Enable verbose output"
    )
    
    args = parser.parse_args()
    
    # Set log level
    if args.verbose:
        logging.getLogger().setLevel(logging.INFO)
    
    # Validate PDF file exists
    pdf_path = Path(args.pdf_file).resolve()
    if not pdf_path.exists():
        logger.error(f"PDF file not found: {pdf_path}")
        sys.exit(1)
    
    # Determine protocol to use
    use_http = args.http
    verify_ssl = args.verify_ssl
    
    # If --http not specified, try HTTPS first, then fall back to HTTP
    if not use_http:
        current_server_pdf = get_server_pdf(args.port, use_http=False, verify_ssl=verify_ssl)
        if current_server_pdf:
            use_http = False  # Server is running on HTTPS
        else:
            # Try HTTP as fallback
            current_server_pdf = get_server_pdf(args.port, use_http=True, verify_ssl=False)
            if current_server_pdf:
                use_http = True  # Server is running on HTTP
                logger.warning("Server running on HTTP (use --http flag to suppress this warning)")
    
    if not current_server_pdf:
        # Server not running - start it (will use HTTPS by default, or HTTP if --http)
        logger.info("Starting pdf_server...")
        if not start_server(pdf_path, args.port, use_http=use_http):
            logger.error("Failed to start pdf_server")
            sys.exit(1)
        
        # Wait for server to start
        time.sleep(1.5)
        
        # Verify server started with correct protocol
        current_server_pdf = get_server_pdf(
            args.port,
            use_http=use_http,
            verify_ssl=verify_ssl if not use_http else False
        )
        if not current_server_pdf:
            logger.error("Server failed to start within timeout")
            sys.exit(1)
        
        logger.info(f"Server started, serving: {current_server_pdf}")
    
    # Check if server is serving a different PDF
    if Path(current_server_pdf).resolve() != pdf_path:
        logger.info("Server serving different PDF, restarting...")
        shutdown_server(args.port, args.api_key, use_http=use_http, verify_ssl=verify_ssl)
        time.sleep(1.5)  # Wait for shutdown
        
        if not start_server(pdf_path, args.port, use_http=use_http):
            logger.error("Failed to restart pdf_server")
            sys.exit(1)
        
        time.sleep(1.5)  # Wait for startup
    
    # Handle forward search if requested
    if args.synctex_forward:
        try:
            line, col, tex_file = parse_synctex_forward(args.synctex_forward)
        except ValueError as e:
            logger.error(f"Invalid --synctex-forward: {e}")
            sys.exit(1)
        
        # Convert tex file path to absolute path for synctex
        tex_path = Path(tex_file).resolve()
        
        logger.info(f"Forward search: line {line}, col {col}, file {tex_path}")
        
        if not send_synctex_request(
            line, col, str(tex_path), str(pdf_path), args.port, args.api_key,
            use_http=use_http, verify_ssl=verify_ssl
        ):
            sys.exit(1)
    else:
        logger.info("PDF opened (no forward search requested)")
    
    sys.exit(0)


if __name__ == "__main__":
    main()
